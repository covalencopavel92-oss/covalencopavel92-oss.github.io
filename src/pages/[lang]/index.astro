---
import { Image } from "astro:assets";
import compressedModelUrl from "../../assets/compressed-model.glb?url";
import Heroimg from "../../assets/Heroimg.jpeg";
import Quiz from "../../components/Quiz.astro";
import { languages } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "ro" | "es");
---
<Layout title={t('nav.home')}>
    <section class="page-view page-view-layout">
        
        <div class="hero-section hero-section-wrapper">
            <div class="reveal">            
                <h1 class="hero-title title-overflow" style="padding-left: 20px; padding-right: 20px;" data-z data-z-layers="5" data-z-depth="15px" data-z-event="pointer" data-z-eventrotation="15deg">
                    <span class="pan-wrapper">

                        {t('index.hero.title').split(' ').map((word, index) => (
                            <>
                            <span class="wave-word" style={`--d:${0.2 + index * 0.2}s`}>{word} </span>
                            {word.endsWith('.') && <br/>}
                            </>
                        ))}

                    </span>
                </h1>
                
                <h2 class="hero-subtitle">
                    {t('index.hero.subtitle')}
                </h2>

                <div class="hero-image-wrapper">
                    <Image src={Heroimg} alt="A man working on a laptop with a coffee mug" class="hero-image-3d" fetchpriority="high" loading="eager" format="webp" widths={[240, 540, 720, 1080, 1600, 1920]} sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1080px) 720px, (max-width: 1600px) 1080px, (max-width: 1920px) 1600px, 1920px`} />
                </div>
                
                <div class="hero-description text-left-indented">
                    <p>{t('index.hero.desc1')}</p>
                    <p>{t('index.hero.desc2')}</p>
                    <p>{t('index.hero.desc3')}</p>
                    <p>{t('index.hero.desc4')}</p>
                </div>
                
                <div class="action-buttons-wrapper">
                    <a href={`/${lang}/services/`} class="btn btn-neon dark-bg reveal" style="transition-delay: 0.1s;">{t('home.explore')}</a>
                    <a href={`/${lang}/about/`} class="btn btn-neon dark-bg reveal" style="transition-delay: 0.1s;">{t('home.assessment')}</a>
                </div>
            </div>
        </div>

        <Quiz />

        <div class="bottom-cta-wrapper reveal">
            <a href={`/${lang}/about/`} class="hover-scale inline-block-transform">
                <model-viewer src={compressedModelUrl} alt="Scale Automata 3D Logo" auto-rotate camera-controls disable-zoom style="width: 150px; height: 150px; --poster-color: transparent;"></model-viewer>
            </a>
        </div>

    </section>
</Layout>

<script is:inline>
    // Initialize ztext on page load for view transitions
    if (!window.ztextInitListenerAdded) {
        document.addEventListener('astro:page-load', () => {
            if (!window.Ztextify && !document.querySelector('script[src="/ztext.min.js"]')) {
                const script = document.createElement('script');
                script.src = "/ztext.min.js";
                script.async = true;
                script.onload = () => {
                   if (document.querySelector('.hero-title')) {
                       new window.Ztextify(".hero-title", {
                           depth: "15px",
                           layers: 5,
                           fade: false,
                           direction: "both",
                           event: "pointer",
                           eventRotation: "15deg"
                       });
                   }
                };
                document.body.appendChild(script);
            } else if (window.Ztextify && document.querySelector('.hero-title')) {
                // Re-initialize if already loaded. Use the same options as data attributes.
                // Ztextify requires a CSS selector string, not an element.
                // Reset innerHTML before applying to prevent compounding layers
                const el = document.querySelector('.hero-title');
                // The ztext.min.js alters the DOM inner HTML heavily.
                // We don't want to re-wrap an already wrapped element
                if (!el.querySelector('.z-text')) {
                    new window.Ztextify(".hero-title", {
                        depth: "15px",
                        layers: 5,
                        fade: false,
                        direction: "both",
                        event: "pointer",
                        eventRotation: "15deg"
                    });
                }
            }
        });
        window.ztextInitListenerAdded = true;
    }
</script>

<style>
    /* 3D typography style for ztext */
    .hero-title .z-text {
        transform: rotateX(5deg) rotateY(-5deg);
        transform-origin: center center;
        transition: transform 0.1s;
    }
    .hero-title {
        text-align: center;
        margin-left: auto;
        margin-right: auto;
    }
    .hero-title .z-layer:not(:first-child) {
        /* Add a subtle shadow/darken effect to deeper layers */
        color: var(--neon-blue);
        filter: brightness(0.5);
    }

    .hero-image-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 2rem 0;
        perspective: 1000px;
    }

    .hero-image-3d {
        width: 85vw;
        aspect-ratio: 16 / 9;
        height: auto;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 30px rgba(0, 255, 255, 0.1);
        transform-style: preserve-3d;
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        /* Subtle continuous floating animation */
        animation: float-3d 6s ease-in-out infinite alternate;
    }

    .hero-image-wrapper:hover .hero-image-3d {
        /* Enhance the 3D pop on hover */
        transform: rotateX(5deg) rotateY(-5deg) translateZ(50px) scale(1.02);
        box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 255, 255, 0.2);
        animation-play-state: paused;
    }

    @keyframes float-3d {
        0% {
            transform: rotateX(2deg) rotateY(-2deg) translateZ(10px);
        }
        100% {
            transform: rotateX(-2deg) rotateY(2deg) translateZ(-10px);
        }
    }
</style>
