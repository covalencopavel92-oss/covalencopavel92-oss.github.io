---
import { Image } from "astro:assets";
import ReviewIm from "../../assets/ReviewIm.jpeg";
import ReviewsComponent from "../../components/Reviews.astro";
import { languages } from "../../i18n/ui";
import { getStaticPaths, useTranslations } from "../../i18n/utils";

import Layout from "../../layouts/Layout.astro";

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.reviews')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('reviews.title')}</h2>
            <p>{t('reviews.subtitle')}</p>
        </div>

        <div class="hero-image-wrapper reveal">
            <Image src={ReviewIm} alt="Reviews Hero Image" class="hero-image-3d" fetchpriority="high" loading="eager" format="webp" widths={[240, 540, 720, 1080, 1600, 1920]} sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1080px) 720px, (max-width: 1600px) 1080px, (max-width: 1920px) 1600px, 1920px`} />
        </div>

        <ReviewsComponent />
    </section>
</Layout>

<style>
    .hero-image-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 2rem 0;
        perspective: 1000px;
    }

    .hero-image-3d {
        width: 95vw;
        aspect-ratio: 16 / 9;
        height: auto;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 30px rgba(0, 255, 255, 0.1);
        transform-style: preserve-3d;
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        /* Subtle continuous floating animation */
        animation: float-3d 6s ease-in-out infinite alternate;
    }

    .hero-image-wrapper:hover .hero-image-3d {
        /* Enhance the 3D pop on hover */
        transform: rotateX(5deg) rotateY(-5deg) translateZ(50px) scale(1.02);
        box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 255, 255, 0.2);
        animation-play-state: paused;
    }

    @keyframes float-3d {
        0% {
            transform: rotateX(2deg) rotateY(-2deg) translateZ(10px);
        }
        100% {
            transform: rotateX(-2deg) rotateY(2deg) translateZ(-10px);
        }
    }
</style>
