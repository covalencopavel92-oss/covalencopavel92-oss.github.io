    <script>
    document.addEventListener('astro:page-load', async () => {
        // ⚡ Bolt Optimization: Use requestAnimationFrame to throttle pointermove
        // calculations to match the display refresh rate, reducing main thread
        // overhead during rapid pointer events, especially from high-polling mice.
        const pendingFrames = new WeakMap<HTMLElement, number>();

        const handlePointerMove = (e: PointerEvent) => {
            const target = e.currentTarget as HTMLElement;

            if (pendingFrames.has(target)) {
                cancelAnimationFrame(pendingFrames.get(target)!);
            }

            const frameId = requestAnimationFrame(() => {
                const rect = target.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                target.style.setProperty("--mouse-x", `${x}px`);
                target.style.setProperty("--mouse-y", `${y}px`);
                target.classList.add("is-hovered");
                pendingFrames.delete(target);
            });

            pendingFrames.set(target, frameId);
        };

        const handlePointerLeave = (e: PointerEvent) => {
            const target = e.currentTarget as HTMLElement;
            if (pendingFrames.has(target)) {
                cancelAnimationFrame(pendingFrames.get(target)!);
                pendingFrames.delete(target);
            }
            target.classList.remove("is-hovered");
        };

        const serviceCards = document.querySelectorAll(".service-card");

        serviceCards.forEach((card) => {
            const el = card as HTMLElement;
            el.addEventListener('pointermove', handlePointerMove);
            el.addEventListener('pointerleave', handlePointerLeave);
            el.addEventListener('pointercancel', handlePointerLeave); // Handle touch/pen disruptions
        });

        // Initialize VanillaTilt on the cards
        if (serviceCards.length > 0) {
            const { default: VanillaTilt } = await import('vanilla-tilt');
            VanillaTilt.init(Array.from(serviceCards) as HTMLElement[], {
                max: 15,
                speed: 400,
                glare: false, // We already have custom glare via CSS variables and hover effect
            });
        }
    });
</script>  

