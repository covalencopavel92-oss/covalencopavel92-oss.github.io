---
import { Image } from "astro:assets";
import ServicesIm from "../../../assets/ServicesIm.jpeg";
import { languages } from "../../../i18n/ui";
import { getStaticPaths, useTranslations } from "../../../i18n/utils";

import Layout from "../../../layouts/Layout.astro";

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.services')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('services.title')}</h2>
            <p>{t('services.subtitle')}</p>
        </div>

        <div class="hero-image-wrapper reveal">
            <Image src={ServicesIm} alt="Services Hero Image" class="hero-image-3d" fetchpriority="high" loading="eager" format="webp" widths={[240, 540, 720, 1080, 1600, 1920]} sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1080px) 720px, (max-width: 1600px) 1080px, (max-width: 1920px) 1600px, 1920px`} />
        </div>

        <div class="services-grid reveal">
            
            <a href={`/${lang}/services/seo-geo/`} class="service-card glass-panel" style="text-decoration: none;">                
                <div class="service-card-glow"></div>
