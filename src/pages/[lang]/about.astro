---
import { Image } from "astro:assets";
import AboutUsIm from "../../assets/AboutUsIm.jpeg";
import compressedModelUrl from "../../assets/compressed-model.glb?url";
import { languages } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
	return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof languages);
---
<Layout title={t('nav.about')}>
    <div class="section-header reveal">
        <h2>About Us</h2>
        <p>Learn more about our mission and the team behind Scale Automata.</p>
    </div>

    <div class="hero-image-wrapper reveal">
        <Image src={AboutUsIm} alt="About Us" class="hero-image-3d" fetchpriority="high" loading="eager" format="webp" widths={[240, 540, 720, 1080, 1600, 1920]} sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1080px) 720px, (max-width: 1600px) 1080px, (max-width: 1920px) 1600px, 1920px`} />
    </div>

    <div class="hero-description text-left-indented reveal">
        <p>We are a forward-thinking digital agency committed to helping businesses thrive in the modern online landscape. Our dedicated team specializes in comprehensive SEO, stunning web design, and data-driven marketing strategies.</p>
        <p>From personalized consulting to fully integrated growth roadmaps, we partner with you at every step of your digital journey. Our goal is to empower your brand with the tools and insights necessary to reach a wider audience and achieve measurable success.</p>
        <p>At Scale Automata, we believe in the power of innovation, transparency, and collaboration. Join us as we build the digital experiences of tomorrow, today.</p>
    </div>

    <div class="reveal" style="display: flex; justify-content: center; margin: 2rem 0;">
        <model-viewer src={compressedModelUrl} alt="Scale Automata 3D Logo" auto-rotate camera-controls disable-zoom style="width: 300px; height: 300px; --poster-color: transparent;"></model-viewer>
    </div>
</Layout>

<style>
    .hero-image-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 2rem 0;
        perspective: 1000px;
    }

    .hero-image-3d {
        width: 95vw;
        aspect-ratio: 16 / 9;
        height: auto;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 30px rgba(0, 255, 255, 0.1);
        transform-style: preserve-3d;
        transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        /* Subtle continuous floating animation */
        animation: float-3d 6s ease-in-out infinite alternate;
    }

    .hero-image-wrapper:hover .hero-image-3d {
        /* Enhance the 3D pop on hover */
        transform: rotateX(5deg) rotateY(-5deg) translateZ(50px) scale(1.02);
        box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 255, 255, 0.2);
        animation-play-state: paused;
    }

    @keyframes float-3d {
        0% {
            transform: rotateX(2deg) rotateY(-2deg) translateZ(10px);
        }
        100% {
            transform: rotateX(-2deg) rotateY(2deg) translateZ(-10px);
        }
    }
</style>
