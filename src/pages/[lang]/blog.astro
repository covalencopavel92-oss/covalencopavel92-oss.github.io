---
import { Image } from "astro:assets";
import BlogIm from "../../assets/BlogIm.jpeg";
import { getStaticPaths, useTranslations } from "../../i18n/utils";

import Layout from "../../layouts/Layout.astro";

export { getStaticPaths };

const { lang } = Astro.params;
const t = useTranslations(lang as "en" | "ro" | "es");
---
<Layout title={t('nav.blog')}>
    <section class="page-view" style="display: block; flex-grow: 1;">
        <div class="section-header reveal">
            <h2>{t('blog.title')}</h2>
            <p>{t('blog.subtitle')}</p>
        </div>

        <div class="hero-image-wrapper reveal">
            <Image src={BlogIm} alt="Blog Hero Image" class="hero-image-3d" fetchpriority="high" loading="eager" format="webp" widths={[240, 540, 720, 1080, 1600, 1920]} sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1080px) 720px, (max-width: 1600px) 1080px, (max-width: 1920px) 1600px, 1920px`} />
        </div>

        <div class="blog-grid reveal">
            <article class="blog-card glass-panel">
                <div class="card-glow"></div>
                <a href={`/${lang}/blog/legacy-systems`} style="display: block;">
                    <div class="blog-img" style="background-image: url('https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80');"></div>
                </a>
                <div class="blog-content">
                    <span style="color: var(--neon-blue); font-size: 0.85rem; font-weight: 600; text-transform: uppercase;">Digital Transformation</span>
                    <h3 style="margin: 0.5rem 0;">Why Legacy Systems are Costing You Customers</h3>
                    <p style="font-size: 0.95rem;">An analysis of hidden costs in maintaining outdated infrastructure versus migrating to modern cloud architectures.</p>
                    <a href={`/${lang}/blog/legacy-systems`} class="read-more">Read Article <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
                </div>
            </article>
            <article class="blog-card glass-panel">
                <div class="card-glow"></div>
                <a href={`/${lang}/blog/core-update`} style="display: block;">
                    <div class="blog-img" style="background-image: url('https://images.unsplash.com/photo-1551288049-bebda4e38f71?auto=format&fit=crop&w=800&q=80');"></div>
                </a>
                <div class="blog-content">
                    <span style="color: var(--neon-blue); font-size: 0.85rem; font-weight: 600; text-transform: uppercase;">SEO</span>
                    <h3 style="margin: 0.5rem 0;">The 2024 Core Update: What You Need to Know</h3>
                    <p style="font-size: 0.95rem;">Search intent is evolving. Learn how to adapt your content strategy to stay ahead of algorithm changes.</p>
                    <a href={`/${lang}/blog/core-update`} class="read-more">Read Article <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
                </div>
            </article>
            <article class="blog-card glass-panel">
                <div class="card-glow"></div>
                <a href={`/${lang}/blog/maximizing-roas`} style="display: block;">
                    <div class="blog-img" style="background-image: url('https://images.unsplash.com/photo-1533750516457-a7f992034fec?auto=format&fit=crop&w=800&q=80');"></div>
                </a>
                <div class="blog-content">
                    <span style="color: var(--neon-blue); font-size: 0.85rem; font-weight: 600; text-transform: uppercase;">Paid Media</span>
                    <h3 style="margin: 0.5rem 0;">Maximizing ROAS with AI-Driven Campaigns</h3>
                    <p style="font-size: 0.95rem;">How we utilize machine learning to predict customer lifetime value and optimize ad spend across platforms.</p>
                    <a href={`/${lang}/blog/maximizing-roas`} class="read-more">Read Article <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></a>
                </div>
            </article>
        </div>
    </section>
    <script>
    document.addEventListener('astro:page-load', async () => {
        // ⚡ Bolt Optimization: Use requestAnimationFrame to throttle pointermove
        // calculations to match the display refresh rate, reducing main thread
        // overhead during rapid pointer events, especially from high-polling mice.
        const pendingFrames = new WeakMap<HTMLElement, number>();

        const handlePointerMove = (e: PointerEvent) => {
            const target = e.currentTarget as HTMLElement;

            if (pendingFrames.has(target)) {
                cancelAnimationFrame(pendingFrames.get(target)!);
            }

            const frameId = requestAnimationFrame(() => {
                const rect = target.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                target.style.setProperty("--mouse-x", `${x}px`);
                target.style.setProperty("--mouse-y", `${y}px`);
                target.classList.add("is-hovered");
                pendingFrames.delete(target);
            });

            pendingFrames.set(target, frameId);
        };

        const handlePointerLeave = (e: PointerEvent) => {
            const target = e.currentTarget as HTMLElement;
            if (pendingFrames.has(target)) {
                cancelAnimationFrame(pendingFrames.get(target)!);
                pendingFrames.delete(target);
            }
            target.classList.remove("is-hovered");
        };

        const blogCards = document.querySelectorAll(".blog-card");

        blogCards.forEach((card) => {
            const el = card as HTMLElement;
            el.addEventListener('pointermove', handlePointerMove);
            el.addEventListener('pointerleave', handlePointerLeave);
            el.addEventListener('pointercancel', handlePointerLeave);
        });

        if (blogCards.length > 0) {
            const { default: VanillaTilt } = await import('vanilla-tilt');
            VanillaTilt.init(Array.from(blogCards) as HTMLElement[], {
                max: 15,
                speed: 400,
                glare: false,
            });
        }
    });
    </script>

    <style>
        .hero-image-wrapper {
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 2rem 0;
            perspective: 1000px;
        }

        .hero-image-3d {
            width: 95vw;
            aspect-ratio: 16 / 9;
            height: auto;
            object-fit: cover;
            border-radius: 12px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), 0 0 30px rgba(0, 255, 255, 0.1);
            transform-style: preserve-3d;
            transition: transform 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            /* Subtle continuous floating animation */
            animation: float-3d 6s ease-in-out infinite alternate;
        }

        .hero-image-wrapper:hover .hero-image-3d {
            /* Enhance the 3D pop on hover */
            transform: rotateX(5deg) rotateY(-5deg) translateZ(50px) scale(1.02);
            box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.7), 0 0 40px rgba(0, 255, 255, 0.2);
            animation-play-state: paused;
        }

        @keyframes float-3d {
            0% {
                transform: rotateX(2deg) rotateY(-2deg) translateZ(10px);
            }
            100% {
                transform: rotateX(-2deg) rotateY(2deg) translateZ(-10px);
            }
        }
    </style>
</Layout>
