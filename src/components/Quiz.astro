<div class="quiz-container reveal" id="quizApp">
    <h3>Digital Needs Assessment</h3>
    <p>Answer 3 quick questions to get a personalized service recommendation.</p>

    <div class="quiz-progress-wrapper">
        <div style="font-size: 0.9rem; margin-bottom: 0.5rem; color: var(--text-light); text-align: left;" aria-live="polite">
            Question <span id="quizCurrentNum">1</span> of <span id="quizTotalNum">3</span>
        </div>
        <div class="quiz-progress-bar" id="quizProgressBar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Assessment Progress">
            <div class="quiz-progress-fill" id="quizProgressFill" style="width: 0%;"></div>
        </div>
    </div>

    <div id="quizQuestion" aria-live="polite" role="status" style="font-size: 1.4rem; font-weight: 600; margin-bottom: 2rem; min-height: 80px;"></div>
    <div class="quiz-options" id="quizOptions"></div>
</div>

<div class="ai-tool-container reveal" id="quizResult" aria-live="polite" role="status" style="display: none;">
    <h3 id="recTitle">Recommendation</h3>
    <div class="ai-result-box" id="recDesc"></div>
    <button class="btn btn-primary" id="retakeQuiz" style="margin-top: 2rem;">Retake Assessment</button>
</div>

<script>
    import { quizData, resultsMap, calculateMaxCategory } from '../logic/quiz';

    // --- NEW: Wrap logic in astro:page-load to support View Transitions ---
    document.addEventListener('astro:page-load', () => {
        const quizApp = document.getElementById('quizApp');
        const quizResult = document.getElementById('quizResult');
        const retakeBtn = document.getElementById('retakeQuiz');

        // Only run the script if the quiz actually exists on the current page
        if (!quizApp) return;

        let currentQuizQuestion = 0;
        let quizScores = { seo: 0, web: 0, consult: 0 };

        function renderQuiz() {
            const qData = quizData[currentQuizQuestion];
            const questionEl = document.getElementById('quizQuestion');
            const optionsEl = document.getElementById('quizOptions');
            const progressFill = document.getElementById('quizProgressFill');
            const progressBar = document.getElementById('quizProgressBar');
            const currentNumEl = document.getElementById('quizCurrentNum');
            const totalNumEl = document.getElementById('quizTotalNum');

            if (!questionEl || !optionsEl) return;

            // Update Progress
            const progressPercent = Math.round((currentQuizQuestion / quizData.length) * 100);
            if (progressFill) progressFill.style.width = `${progressPercent}%`;
            if (progressBar) progressBar.setAttribute('aria-valuenow', progressPercent.toString());
            if (currentNumEl) currentNumEl.innerText = (currentQuizQuestion + 1).toString();
            if (totalNumEl) totalNumEl.innerText = quizData.length.toString();

            questionEl.innerText = qData.question;
            optionsEl.replaceChildren();

            // ⚡ Bolt Optimization: Use DocumentFragment to batch DOM insertions
            // This prevents multiple reflows when rendering quiz options.
            const fragment = document.createDocumentFragment();
            qData.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'quiz-btn';
                btn.innerText = opt.text;
                btn.onclick = () => answerQuiz(opt.score);
                fragment.appendChild(btn);
            });
            optionsEl.appendChild(fragment);
        }

        function answerQuiz(scoreType) {
            if (quizScores[scoreType] !== undefined) {
                 quizScores[scoreType]++;
            }
            currentQuizQuestion++;

            if(currentQuizQuestion < quizData.length) {
                renderQuiz();
            } else {
                showQuizResult();
            }
        }

        function showQuizResult() {
            if(quizApp) quizApp.style.display = 'none';

            const maxCategory = calculateMaxCategory(quizScores);

            const recTitle = document.getElementById('recTitle');
            const recDesc = document.getElementById('recDesc');
            if(recTitle) recTitle.innerText = resultsMap[maxCategory].title;
            if(recDesc) recDesc.innerText = resultsMap[maxCategory].desc;
            if(quizResult) quizResult.style.display = 'block';
        }

        function resetQuiz() {
            currentQuizQuestion = 0;
            quizScores = { seo: 0, web: 0, consult: 0 };
            if(quizResult) quizResult.style.display = 'none';
            if(quizApp) quizApp.style.display = 'block';
            renderQuiz();
        }

        // Initialize Quiz
        renderQuiz();

        if (retakeBtn) {
            retakeBtn.addEventListener('click', resetQuiz);
        }
    });
</script>