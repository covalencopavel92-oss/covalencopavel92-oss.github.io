---
import { useTranslations } from "../i18n/utils";

const lang = (Astro.params.lang || "en") as "en" | "ro" | "es";
const t = useTranslations(lang);
---
<div class="contact-wrapper reveal">
    <form id="contactForm">
        <!-- Honeypot -->
        <div style="display:none;">
            <label for="honeypot">Leave this field empty</label>
            <input type="text" id="honeypot" name="honeypot">
        </div>

        <div class="floating-group">
            <input type="text" class="floating-input" id="name" name="name" required>
            <label class="floating-label" for="name">{t('contact.name')}</label>
        </div>
        <div class="floating-group">
            <input type="email" class="floating-input" id="email" name="email" required>
            <label class="floating-label" for="email">{t('contact.email')}</label>
        </div>
        <div class="floating-group">
            <input type="text" class="floating-input" id="subject" name="subject" required>
            <label class="floating-label" for="subject">{t('contact.subject')}</label>
        </div>
        <div class="floating-group">
            <textarea class="floating-input" id="message" name="message" required></textarea>
            <label class="floating-label" for="message">{t('contact.message')}</label>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; display: flex; justify-content: center; align-items: center; gap: 8px;">
            <svg id="submitSpinner" style="display: none; width: 16px; height: 16px;" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-spinner"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg>
            <span id="submitText">{t('contact.send')}</span>
        </button>
        <div class="form-message" id="formMessage" aria-live="polite" role="status">{t('contact.success')}</div>
    </form>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contactForm');
        if (form) {
            form.addEventListener('submit', (e) => {
                e.preventDefault();

                // Check honeypot
                const honeypot = (document.getElementById('honeypot') as HTMLInputElement).value;
                if (honeypot) {
                    return; // Silently fail
                }

                const btn = form.querySelector('button');
                const spinner = document.getElementById('submitSpinner');
                if (!btn) return;

                if (spinner) spinner.style.display = 'block';
                btn.style.opacity = '0.8';
                btn.style.transform = 'scale(0.98)';
                btn.disabled = true;
                btn.style.cursor = 'not-allowed';

                setTimeout(() => {
                    const msg = document.getElementById('formMessage');
                    if(msg) msg.style.display = 'block';
                    (form as HTMLFormElement).reset();
                    if (spinner) spinner.style.display = 'none';
                    btn.style.opacity = '1';
                    btn.style.transform = 'none';
                    btn.disabled = false;
                    btn.style.cursor = '';

                    setTimeout(() => {
                        if(msg) msg.style.display = 'none';
                    }, 5000);
                }, 1500);
            });
        }
    });
</script>
